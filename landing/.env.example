# Landing waitlist storage — a SEPARATE Supabase project, NOT the app's.
# Create a new project (e.g. EU region), run waitlist.sql in it, then paste:
LANDING_SUPABASE_URL=https://YOUR-LANDING-PROJECT.supabase.co
LANDING_SUPABASE_ANON_KEY=sb_publishable_xxx

# Founder-messages inbox — writes to the MAIN app Supabase project (the same
# one the app uses). Use the URL + publishable/anon key, NEVER the service key.
MAIN_SUPABASE_URL=https://YOUR-APP-PROJECT.supabase.co
MAIN_SUPABASE_ANON_KEY=sb_publishable_xxx
