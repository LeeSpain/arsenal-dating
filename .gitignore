# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Vercel
.vercel/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# generated native folders
/ios
/android

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# typescript
*.tsbuildinfo

# template example output
example

# Environment & secrets — never commit real keys (allow the example only)
.env*
!.env.example

# Supabase local state
supabase/.branches
supabase/.temp
supabase/.env

# IDE
.idea/

# Landing image sources — the multi-MB Gemini PNGs are run through
# landing/scripts/optimize-images.mjs to produce the JPGs we ship. The PNGs
# themselves never need to reach git or the deployed site.
landing/public/images/*.png
